<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trivia Electoral CABA (1996-2026)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        
        body {
            font-family: 'Archivo', sans-serif;
            background-color: #8DE2D6;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
        }

        .card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        .option-btn {
            transition: all 0.2s ease;
        }

        .option-btn:hover {
            transform: translateY(-2px);
            background-color: #ebf5ff;
        }

        .correct {
            background-color: #10b981 !important;
            color: white !important;
            border-color: #059669 !important;
        }

        .incorrect {
            background-color: #ef4444 !important;
            color: white !important;
            border-color: #dc2626 !important;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div id="app" class="w-full max-w-2xl bg-white rounded-3xl card-shadow overflow-hidden">
        <!-- Pantalla de Inicio -->
        <div id="start-screen" class="p-8 text-center">
            <div class="mb-6 inline-block p-4 bg-blue-100 rounded-full text-blue-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h1 class="text-3xl font-bold text-gray-800 mb-2">Desafío Ciudad Autónoma</h1>
            <p class="text-gray-600 mb-8">Pon a prueba tus conocimientos sobre la reforma y el sistema electoral de la Ciudad (1996-2026).</p>
            
            <div class="max-w-xs mx-auto space-y-4">
                <input type="text" id="username" placeholder="Ingresa tu nombre" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition-all">
                <button onclick="startTrivia()" class="w-full gradient-bg text-white font-bold py-3 px-6 rounded-xl hover:opacity-90 transition-all shadow-lg">
                    Comenzar Trivia
                </button>
            </div>
        </div>

        <!-- Pantalla de Juego -->
        <div id="quiz-screen" class="hidden">
            <div class="gradient-bg p-6 text-white flex justify-between items-center">
                <div>
                    <p class="text-blue-100 text-sm uppercase tracking-wider font-semibold">Pregunta</p>
                    <p class="text-2xl font-bold"><span id="current-question-num">1</span> <span class="text-blue-300">/ 10</span></p>
                </div>
                <div class="text-right">
                    <p class="text-blue-100 text-sm uppercase tracking-wider font-semibold">Puntaje</p>
                    <p id="score-display" class="text-2xl font-bold">0</p>
                </div>
            </div>
            
            <div class="p-8">
                <h2 id="question-text" class="text-xl font-bold text-gray-800 mb-6 leading-tight">Cargando pregunta...</h2>
                <div id="options-container" class="space-y-3">
                    <!-- Las opciones se generarán aquí -->
                </div>
            </div>

            <div class="px-8 pb-8 flex justify-end">
                <button id="next-btn" onclick="nextQuestion()" class="hidden bg-gray-800 text-white font-bold py-3 px-8 rounded-xl hover:bg-gray-700 transition-all shadow-md">
                    Siguiente
                </button>
            </div>
        </div>

        <!-- Pantalla de Resultados -->
        <div id="result-screen" class="hidden p-8 text-center">
            <div class="mb-4 inline-block p-4 bg-yellow-100 rounded-full text-yellow-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            </div>
            <h2 class="text-3xl font-bold text-gray-800 mb-2">¡Trivia Completada!</h2>
            <p id="final-stats" class="text-xl text-gray-600 mb-8"></p>
            
            <div class="bg-gray-50 rounded-2xl p-6 mb-8">
                <h3 class="text-lg font-bold text-gray-700 mb-4 flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 21v-4a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v4"/><path d="M18 21V9a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v12"/><path d="M2 21h20"/></svg>
                    Ranking de la Ciudad
                </h3>
                <div id="leaderboard" class="space-y-2 text-left max-h-48 overflow-y-auto">
                    <!-- Los rankings aparecerán aquí -->
                </div>
            </div>

            <button onclick="resetTrivia()" class="w-full bg-blue-600 text-white font-bold py-3 px-6 rounded-xl hover:bg-blue-700 transition-all shadow-lg">
                Intentar de nuevo
            </button>
        </div>
    </div>

    <script>
        const questions = [
            {
                q: "¿En qué año se sancionó la Constitución de la Ciudad que estableció su autonomía?",
                o: ["1994", "1996", "2000", "2018"],
                a: 1
            },
            {
                q: "¿Cuántos miembros integran la Legislatura de la Ciudad de Buenos Aires en su totalidad?",
                o: ["30", "45", "60", "72"],
                a: 2
            },
            {
                q: "¿Qué sistema se utiliza para la distribución de bancas proporcionales en la Legislatura?",
                o: ["Sistema Mayoritario", "Sistema D'Hondt", "Doble voto simultáneo", "Lista incompleta"],
                a: 1
            },
            {
                q: "¿Qué organismo autárquico se encarga de la administración de las elecciones según el Código Electoral de 2018?",
                o: ["Tribunal Superior", "Instituto de Gestión Electoral (IGE)", "Dirección General Electoral", "Instituto de Estadística"],
                a: 1
            },
            {
                q: "¿Desde qué año el empadronamiento de residentes extranjeros es automático en la Ciudad?",
                o: ["2015", "2019", "2021", "2023"],
                a: 2
            },
            {
                q: "¿Cuántos integrantes tiene cada órgano colegiado denominado Junta Comunal?",
                o: ["3 integrantes", "5 integrantes", "7 integrantes", "15 integrantes"],
                a: 2
            },
            {
                q: "¿Cuál fue el instrumento de votación utilizado en las elecciones de mayo 2025?",
                o: ["Boleta Múltiple Partidaria", "Boleta Única Papel", "Boleta Única Electrónica", "Voto por Correo"],
                a: 2
            },
            {
                q: "¿Qué porcentaje de bancas de la Legislatura renovadas en 2025 fue ocupado por mujeres?",
                o: ["30%", "42%", "50%", "60%"],
                a: 2
            },
            {
                q: "¿A partir de qué edad pueden votar los jóvenes en la Ciudad de Buenos Aires?",
                o: ["14 años", "16 años", "18 años", "21 años"],
                a: 1
            },
            {
                q: "¿Cuántas bancas de la Legislatura se renuevan cada dos años?",
                o: ["Las 60 totales", "15 bancas", "30 bancas", "Depende del año"],
                a: 2
            }
        ];

        let state = {
            username: "",
            currentQuestion: 0,
            score: 0,
            answered: false
        };

        function startTrivia() {
            const nameInput = document.getElementById('username');
            if (!nameInput.value.trim()) {
                nameInput.classList.add('border-red-500');
                return;
            }
            state.username = nameInput.value.trim();
            document.getElementById('start-screen').classList.add('hidden');
            document.getElementById('quiz-screen').classList.remove('hidden');
            loadQuestion();
        }

        function loadQuestion() {
            state.answered = false;
            const qData = questions[state.currentQuestion];
            document.getElementById('current-question-num').innerText = state.currentQuestion + 1;
            document.getElementById('question-text').innerText = qData.q;
            document.getElementById('next-btn').classList.add('hidden');
            
            const container = document.getElementById('options-container');
            container.innerHTML = "";
            
            qData.o.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "option-btn w-full text-left px-6 py-4 border-2 border-gray-100 rounded-2xl font-medium text-gray-700 bg-gray-50 hover:border-blue-400";
                btn.innerText = opt;
                btn.onclick = () => selectOption(idx, btn);
                container.appendChild(btn);
            });
        }

        function selectOption(idx, element) {
            if (state.answered) return;
            state.answered = true;
            
            const correctIdx = questions[state.currentQuestion].a;
            const allBtns = document.querySelectorAll('.option-btn');
            
            if (idx === correctIdx) {
                element.classList.add('correct');
                state.score += 100;
                document.getElementById('score-display').innerText = state.score;
            } else {
                element.classList.add('incorrect');
                allBtns[correctIdx].classList.add('correct');
            }
            
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function nextQuestion() {
            state.currentQuestion++;
            if (state.currentQuestion < questions.length) {
                loadQuestion();
            } else {
                showResults();
            }
        }

        function showResults() {
            document.getElementById('quiz-screen').classList.add('hidden');
            document.getElementById('result-screen').classList.remove('hidden');
            
            document.getElementById('final-stats').innerText = `${state.username}, obtuviste ${state.score} puntos de ${questions.length * 100}.`;
            
            saveToLeaderboard();
            displayLeaderboard();
        }

        function saveToLeaderboard() {
            let leaderboard = JSON.parse(localStorage.getItem('trivia_caba_ranking') || "[]");
            leaderboard.push({ name: state.username, score: state.score });
            // Ordenar por puntaje y limitar a top 5
            leaderboard.sort((a, b) => b.score - a.score);
            leaderboard = leaderboard.slice(0, 10);
            localStorage.setItem('trivia_caba_ranking', JSON.stringify(leaderboard));
        }

        function displayLeaderboard() {
            const container = document.getElementById('leaderboard');
            const leaderboard = JSON.parse(localStorage.getItem('trivia_caba_ranking') || "[]");
            
            if (leaderboard.length === 0) {
                container.innerHTML = "<p class='text-gray-400 text-center'>No hay récords registrados aún.</p>";
                return;
            }

            container.innerHTML = leaderboard.map((entry, i) => `
                <div class="flex justify-between items-center p-3 ${entry.name === state.username ? 'bg-blue-100 rounded-lg font-bold' : 'border-b border-gray-100'}">
                    <span class="text-gray-700"><span class="w-6 inline-block">${i+1}.</span> ${entry.name}</span>
                    <span class="text-blue-600">${entry.score} pts</span>
                </div>
            `).join('');
        }

        function resetTrivia() {
            state = {
                username: state.username, // Conservamos el nombre para facilidad
                currentQuestion: 0,
                score: 0,
                answered: false
            };
            document.getElementById('score-display').innerText = 0;
            document.getElementById('result-screen').classList.add('hidden');
            document.getElementById('quiz-screen').classList.remove('hidden');
            loadQuestion();
        }
    </script>
</body>
</html>
